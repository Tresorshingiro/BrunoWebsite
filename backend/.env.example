# Database
MONGODB_URI=mongodb://localhost:27017/brunowebsite

# JWT Secret
JWT_SECRET=your_jwt_secret_key_here

# Client Origin (Frontend URL) - for CORS
# Development: http://localhost:5173
# Production: https://bruno-iradukunda.vercel.app
CLIENT_ORIGIN=http://localhost:5173

# Stripe (Payment Processing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Server Port
PORT=5000

# Email (for sending contact form notifications)
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password
# Bruno's personal inbox — contact form messages are forwarded here
NOTIFY_EMAIL=your_gmail
